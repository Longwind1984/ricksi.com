---
// Galaxy View 项目落地页 v2：整页星系背景 + 体验优先动线（Rick 第一人称口吻）
// 背景 = 程序化星云（galaxy-hero.js，固定整页 + 滚出首屏冻结）
// 主 CTA = 全屏浮层跑真实知识库 3D（graph-view-galaxy.js renderGraph3D + 真实 graph.json）
// 数据口径出自 Galaxy_View/docs/writer-handoff.json（已核实）
import Glass from '../../layouts/Glass.astro';
import { loadSiteData } from '../../lib/site-data.mjs';

const REPO = 'https://github.com/Longwind1984/galaxy-view';

// 真实已发布、已脱敏的知识图谱（与首页 /graph 同源）；内联给浮层的真渲染器消费
const { graph } = loadSiteData();
const graphJson = graph ? JSON.stringify({ graph }).replace(/</g, '\\u003c') : null;

// 一眼看懂成果带
const glance = ['已上架 Obsidian 社区插件', '4 天 · 14 commit', '16 → 60 fps', '22,000 → 19 draw calls', '性能超越全部 4 个前辈'];

// 前辈墓地：市面 4 个同类插件全停更、全死于逐对象渲染
const tombs = [
  { name: 'obsidian-3d-graph', who: 'AlexW00', note: '374 ★ · 2023-10 起停更' },
  { name: '3D Graph New', who: 'HananoshikaYomaru', note: '作者自述：不知道怎么修' },
  { name: 'New 3D Graph', who: 'Apoo711', note: '停更 10+ 个月' },
  { name: 'Tags Routes', who: 'kctekn', note: '停更 10+ 个月' },
];

// 四个头条指标（before→after + 条形宽度，accent=after=改进；方向由颜色而非长短表达）
const stats = [
  { before: '16.2', after: 60, k: '环绕帧率 fps', bw: 27, aw: 100 },
  { before: '22,000', after: 19, k: 'draw calls / 帧', bw: 100, aw: 3 },
  { before: '61s', after: 0, unit: 'ms', k: '冷布局主线程阻塞', bw: 100, aw: 2 },
  { before: '1.3MB', after: 665, sep: true, unit: 'KB', k: '包体', bw: 100, aw: 51 },
];

// 同机同库三代基准
const bench = [
  { k: 'S1 沉降后环绕（含 bloom）', m0: '16.2 fps', m1: '60.0 fps', m3: '60.0 fps' },
  { k: 'S2 冷布局主线程阻塞', m0: '61s（最长 860ms）', m1: '5.2s', m3: '5.8s · 0 阻塞' },
  { k: 'S3 含未解析 9,437 节点', m0: '13.8 fps', m1: '60.0 fps', m3: '60.0 fps' },
  { k: '每帧 draw calls', m0: '约 22,000', m1: '19', m3: '19' },
  { k: 'S4 开关 ×10 堆增量', m0: '+13.7 MB', m1: '−1.0 MB', m3: '−3.7 MB' },
  { k: '包体', m0: '1.3 MB', m1: '606 KB', m3: '665 KB' },
];

// 里程碑：4 天、M0–M5。story 有值则可展开（战争故事）
const miles = [
  { id: 'M0', date: '06-12', t: '真实数据性能尖刺',
    d: '先用真实 vault 跑 stock 方案，预先定好 45/30 fps 红黄绿门槛。结果 S1 = 16.2 fps，判红。按预案：把「聚合渲染」从 M3 提前到 M1。坏结果是计划内的分支，不是临场救火。' },
  { id: 'M1', date: '06-12', t: '聚合渲染器',
    d: '全部节点 1 次 draw call、全部链接 1 次 draw call，弃用 3d-force-graph 运行时。16 → 60 fps，22,000 → 19 draw calls，冷布局 61 秒卡死变成 5 秒星系成形动画。',
    story: '泄漏金丝雀首读 +181MB 触发红灯。连续两轮对照发现第二轮起始堆比第一轮还低——根源是 d3 每 tick 重建八叉树产生海量短命垃圾，忙循环里 GC 不跑。修正测量方法后终判 −1MB。教训：真泄漏判据是多轮起始堆持续抬升，单轮 delta 不可信。' },
  { id: 'M1.5–M2.6', date: '06-12 ~ 13', t: '反馈驱动的几轮打磨',
    d: '辉光/力学/外观控制面板、Lightroom 式滑杆、FPS 飞行与平移、聚焦模式、双视觉方向、4 种风格预设、6 组配色主题、亮星眨眼、创世动画。每一轮都是我看着跑起来的版本提反馈、再翻译成实现。',
    story: '「⌘/Ctrl 拖平移没反应」排查到最后，根因不是触控板——macOS 把 Ctrl+点击征用为系统右键模拟，事件根本到不了插件。改成 ⌘ / Shift / 右键三通道平移。' },
  { id: 'M3', date: '06-13', t: '性能硬化：Worker 布局',
    d: 'd3-force-3d 完全搬到 Web Worker，坐标用 transferable 双缓冲零拷贝回传。冷布局主线程阻塞 61s → 0ms。「布局期间编辑笔记零卡顿」从此是架构保证。',
    story: '真机实测抓到镜头穿进星团内部掉到 8fps——满屏大发光精灵打爆 GPU 填充率。用 shader 里 uMaxPoint = 110dp 钳制点尺寸修复（背景这座星云也用了同一招）。' },
  { id: 'M4–M4.1', date: '06-13', t: '移动端三档质量',
    d: 'high / low / mobile 三档：mobile 关 bloom（热核保住约 80% 观感）、节点帽 1500（保 94% 链接质量）、卡片改底部抽屉。FPS 看门狗连续 <30fps 单向降档。iPhone 实测 61fps、6 draw calls。',
    story: '底部卡片与系统操作栏重叠。Obsidian 没暴露 .mobile-navbar 高度、且该栏在某些形态下根本不存在——改用运行时实测重叠像素写入 CSS 变量，无栏时为 0，零空白。' },
  { id: 'M5', date: '06-13 ~ 15', t: '发布 · 上架社区插件',
    d: 'esbuild define 门控剔除开发期命令、MIT LICENSE、中英 README、GitHub Actions 打 tag 自动发版；官方审核通过，正式上架 Obsidian 社区插件市场——现在任何人搜「Galaxy View」就能装。' },
];
---

<Glass
  title="Galaxy View · 把笔记库变成可飞行的星系 · Rick Si"
  description="Galaxy View：我给 Obsidian 写的电影感 3D 图谱插件，已上架社区插件市场。聚合渲染把 22,000 次 draw call 压到 19，帧率 16→60，性能与 NASA 式观感在同一个方案里汇合。"
  active="projects"
  space
>
  <!-- 整页固定星系背景（程序化星云，滚出首屏冻结） -->
  <div class="gv-bg" id="gv-bg" aria-hidden="true"></div>

  <main class="gv-main">
    <!-- ============ Hero ============ -->
    <section class="gv-hero">
      <div class="container gv-hero-inner">
        <nav class="mono gv-crumb"><a href="/#projects">← 项目</a></nav>
        <div class="mono kicker gv-kicker">OBSIDIAN 社区插件 · 已上架 · 开源 MIT</div>
        <h1 class="gv-h1">把笔记库，<br />变成一座能飞进去的星系。</h1>
        <p class="gv-sub">
          Obsidian 把几千篇笔记用双链织成一张网，但自带的 2D 图谱到这个规模就糊成一团。Galaxy View 把它变成一座能飞进去的 3D 星系——几万条边照样跑满 60 帧。
        </p>
        <div class="gv-cta-row">
          <button class="btn-accent big gv-open" id="gv-open" type="button">飞进我的知识库 →</button>
          <a class="gv-ghost" href="#story">看看怎么做的 ↓</a>
        </div>
        <ul class="gv-glance">
          {glance.map((g) => <li class="mono gv-glance-item">{g}</li>)}
        </ul>
      </div>

      <div class="gv-ctl-row">
        <button class="gv-ctl mono" id="gv-theme" type="button" aria-label="切换背景配色">
          <span class="gv-ctl-k">配色</span><span class="gv-ctl-v">钴蓝之夜</span>
        </button>
        <button class="gv-ctl mono" id="gv-bloom" type="button" aria-pressed="true" aria-label="开关辉光">
          <span class="gv-ctl-k">辉光</span><span class="gv-ctl-v">开</span>
        </button>
      </div>
      <div class="mono gv-hint">拖拽背景旋转 · 切换配色 · 这是程序化星云；点「飞进我的知识库」进真实笔记库的实时 3D</div>
    </section>

    <div class="container" id="story">
      <!-- ============ 命题 ============ -->
      <section class="sec gv-reveal">
        <div class="mono kicker">为什么做</div>
        <p class="gv-lead">颜值即生产力——但惊艳来自<em>克制</em>。</p>
        <p class="gv-body">
          我赌一件事：对个人知识库来说，颜值和可玩性本身就是生产力。一个让你愿意一头扎进去的图谱，比任何整理方法论都管用。
          但「惊艳」不靠特效堆砌。NASA 的 <a href="https://eyes.nasa.gov/apps/asteroids/#/home" target="_blank" rel="noreferrer">Eyes on Asteroids</a> 给了答案：纯黑底、选择性辉光、慢镜头。高级感来自克制——这成了整个视觉系统的纲领。
        </p>
      </section>

      <!-- ============ 问题 + 前辈墓地 ============ -->
      <section class="sec gv-reveal">
        <div class="sec-head">
          <span class="mono sec-no">01</span>
          <div class="sec-title-row"><h2 class="sec-title">一团糊，和四座墓碑</h2><span class="mono sec-en">THE WALL</span></div>
          <span class="sec-desc">问题与前人死因</span>
        </div>
        <p class="gv-body">
          我的库有 3,225 篇笔记、近 2 万条双链。Obsidian 自带的 2D Graph 在这个规模下只剩一团糊——想看「哪些笔记其实连在一起」，根本看不出来。
        </p>
        <p class="gv-body">
          市面上有 4 个 3D 图谱插件。我一个个翻过去：全停更了 10 个月以上，全是同一个库的薄封装，全死在同一堵墙——<strong>逐对象渲染</strong>。一个节点一个 Mesh、一条边一个 Line，真实库规模下一帧约 <strong>2.2 万次 draw call</strong>，GPU 扛不住。其中一个作者在 README 里直接写：<span class="gv-quote">"performance issue that I don't know how to fix"</span>。
        </p>
        <div class="gv-tombs">
          {tombs.map((p) => (
            <div class="gv-tomb">
              <div class="gv-tomb-name">{p.name}</div>
              <div class="mono gv-tomb-who">{p.who}</div>
              <div class="mono gv-tomb-note">{p.note}</div>
            </div>
          ))}
        </div>
        <div class="gv-decision">
          <span class="mono gv-decision-tag">决策</span>
          <div class="gv-decision-body">
            <p class="gv-decision-call"><strong>不 fork，全新构建。</strong></p>
            <p class="gv-decision-why">它们都是 MIT、都停更、都死于同一堵墙。fork = 继承那块天花板。<em>被否决：fork 最活跃的 Apoo711 版本。</em>参考可以，继承不行。</p>
          </div>
        </div>
      </section>

      <!-- ============ 突破 ============ -->
      <section class="sec gv-reveal gv-break">
        <div class="sec-head">
          <span class="mono sec-no">02</span>
          <div class="sec-title-row"><h2 class="sec-title">性能与美学，在同一个方案里汇合</h2><span class="mono sec-en">AGGREGATE RENDER</span></div>
          <span class="sec-desc">核心突破</span>
        </div>
        <p class="gv-body">
          我押的方案是<strong>聚合渲染</strong>。不再一个节点一个对象——全部节点压成一次 <code>THREE.Points</code>，配一个径向衰减的发光球 shader；全部链接压成一次 <code>LineSegments</code>。整帧含辉光不到 20 次 draw call。
        </p>
        <div class="gv-bignum-wrap">
          <div class="gv-bignum">
            <span class="gv-num" data-count="22000" data-sep="1">0</span>
            <span class="gv-bignum-arrow">→</span>
            <span class="gv-num gv-bignum-after" data-count="19">0</span>
          </div>
          <div class="mono gv-bignum-cap">每帧 draw calls · 同机同库实测</div>
        </div>
        <p class="gv-body">
          关键在于：这个点精灵发光 shader，<strong>本身就是</strong> NASA 那种「发光球」的观感来源。同一个方案，一边把前辈撞死的那堵墙拆了，一边给了我要的颜值——它俩在这儿汇合。点开「飞进我的知识库」，跑的就是这套渲染器，喂的是我自己 3,225 篇笔记的真实双链。
        </p>
      </section>

      <!-- ============ 数字 ============ -->
      <section class="sec gv-reveal">
        <div class="sec-head">
          <span class="mono sec-no">03</span>
          <div class="sec-title-row"><h2 class="sec-title">数字</h2><span class="mono sec-en">BENCHMARKS</span></div>
          <span class="sec-desc">同一台 Mac、同一个库，三代留痕</span>
        </div>
        <div class="gv-stats">
          {stats.map((s) => (
            <div class="gv-stat">
              <div class="gv-stat-pair">
                <span class="gv-stat-before">{s.before}</span>
                <span class="gv-stat-arrow">→</span>
                <span class="gv-num gv-stat-after" data-count={String(s.after)} data-sep={s.sep ? '1' : undefined}>0</span>
                {s.unit && <span class="gv-stat-unit">{s.unit}</span>}
              </div>
              <div class="gv-bar"><span class="gv-bar-b" style={`width:${s.bw}%`}></span><span class="gv-bar-a" style={`width:${s.aw}%`}></span></div>
              <div class="mono gv-stat-k">{s.k}</div>
            </div>
          ))}
        </div>
        <div class="gv-table-wrap">
          <table class="gv-table mono">
            <thead><tr><th>场景</th><th>M0 stock</th><th>M1 聚合</th><th>M3 +Worker</th></tr></thead>
            <tbody>
              {bench.map((r) => (
                <tr><td class="gv-td-k">{r.k}</td><td class="gv-td-dim">{r.m0}</td><td>{r.m1}</td><td class="gv-td-hi">{r.m3}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- ============ 逆向 NASA Eyes ============ -->
      <section class="sec gv-reveal">
        <div class="sec-head">
          <span class="mono sec-no">04</span>
          <div class="sec-title-row"><h2 class="sec-title">不是模仿，是逆向</h2><span class="mono sec-en">NASA EYES, REVERSED</span></div>
          <span class="sec-desc">观感从何而来</span>
        </div>
        <p class="gv-body">
          我没靠感觉去模仿那种观感。直接把 NASA「Eyes on Asteroids」的生产 JS 抓下来 grep 了一遍，确认它到底用了什么配方——然后照着复刻：
        </p>
        <ul class="gv-recipe">
          <li><span class="mono">three.js r167</span> + WebGLRenderer</li>
          <li><span class="mono">UnrealBloomPass</span>，且 bloom 强度运行时可调</li>
          <li>DOM 浮层标签，不是画布内文字（CJK 清晰、可换肤）</li>
          <li>细的、低饱和的轨道线，辉光交给 bloom 给</li>
          <li>远处精灵、近处网格的 LOD</li>
          <li><strong>无雾、无暗角、无颗粒</strong></li>
        </ul>
        <p class="gv-note">结论就一句：高级感来自克制（premium feel = restraint）。</p>
      </section>

      <!-- ============ 里程碑 / 工程纪律 ============ -->
      <section class="sec gv-reveal">
        <div class="sec-head">
          <span class="mono sec-no">05</span>
          <div class="sec-title-row"><h2 class="sec-title">4 天，每一步先定数字再开工</h2><span class="mono sec-en">MILESTONES</span></div>
          <span class="sec-desc">14 次 commit · M0 → M5</span>
        </div>
        <div class="gv-decision">
          <span class="mono gv-decision-tag">决策</span>
          <div class="gv-decision-body">
            <p class="gv-decision-call"><strong>每个里程碑先定 pass/fail 数字，再开工。</strong></p>
            <p class="gv-decision-why">M0 判红（16.2 fps）触发的是预设的「聚合渲染提前」分支——把风险前置成可量化的 go/no-go，坏结果是计划内转向，不是临场救火。</p>
          </div>
        </div>
        <ol class="gv-time">
          {miles.map((m) => (
            <li class="gv-mile">
              <div class="gv-mile-head">
                <span class="mono gv-mile-id">{m.id}</span>
                <span class="mono gv-mile-date">{m.date}</span>
                <h3 class="gv-mile-t">{m.t}</h3>
              </div>
              <p class="gv-mile-d">{m.d}</p>
              {m.story && (
                <details class="gv-story">
                  <summary class="mono">战争故事 ↘</summary>
                  <p>{m.story}</p>
                </details>
              )}
            </li>
          ))}
        </ol>
      </section>

      <!-- ============ 品味落到细节 ============ -->
      <section class="sec gv-reveal">
        <div class="sec-head">
          <span class="mono sec-no">06</span>
          <div class="sec-title-row"><h2 class="sec-title">品味落到细节</h2><span class="mono sec-en">THE CRAFT</span></div>
          <span class="sec-desc">颜值即生产力的具体兑现</span>
        </div>
        <div class="gv-craft">
          <div class="gv-craft-card">
            <h3 class="gv-craft-t">星星只挑最亮的 3% 眨眼</h3>
            <p>同一时刻最多一颗、泊松随机间隔——做成偶发的大气闪烁，不是圣诞彩灯。</p>
          </div>
          <div class="gv-craft-card">
            <h3 class="gv-craft-t">扁平星系要一股额外的力</h3>
            <p>自然引斥力只会形成球。加一个只作用于 Y 轴的向心力，才把球压成旋转盘——还做成可连续调的滑杆。</p>
          </div>
          <div class="gv-craft-card">
            <h3 class="gv-craft-t">浅色不是把深色调亮</h3>
            <p>另设计了一套「晨昼制图室」：暖纸底、关辉光、墨水圆盘节点、铅笔线链接。是两套设计，不是一套的明暗。</p>
          </div>
          <div class="gv-craft-card">
            <h3 class="gv-craft-t">飞向节点时不正对它</h3>
            <p>落点偏 15°、优先扫过邻居密集的那一侧——像飞船靠近，而不是被瞬移正对。</p>
          </div>
        </div>
      </section>

      <!-- ============ 怎么做出来的（克制版） ============ -->
      <section class="sec gv-reveal">
        <div class="mono kicker">怎么做出来的</div>
        <p class="gv-body gv-method">
          写第一行代码前，我先并行做了技术调研和多视角设计（架构 / 视觉 / 风险），产出一份带数字门控的实施计划，而不是边写边想。整个研发我和一个 AI 编码 agent 协作完成——方向、取舍和审美判断我来定，靠对每一版运行结果的反馈一轮轮收敛。上面那些「反馈驱动的打磨」，就是这套节奏。
        </p>
      </section>

      <!-- ============ 状态 + 安装 ============ -->
      <section class="sec gv-reveal gv-end">
        <div class="sec-head">
          <span class="mono sec-no">07</span>
          <div class="sec-title-row"><h2 class="sec-title">现在就能装</h2><span class="mono sec-en">GET IT</span></div>
          <span class="sec-desc">已上架，搜名字就行</span>
        </div>
        <div class="gv-chips">
          <span class="tag mono">✅ 已上架 Obsidian 社区插件</span>
          <span class="tag mono">MIT</span>
          <span class="tag mono">移动端随首发 · iPhone 61fps</span>
          <span class="tag mono">4 天 · 14 commit</span>
        </div>
        <p class="gv-body gv-stack">
