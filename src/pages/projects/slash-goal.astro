  .sg-code { position: relative; border-radius: var(--r-card, 16px); background: rgba(4,8,20,0.5); border: 1px solid rgba(190,210,255,0.12); padding: 12px 14px; overflow: hidden; display: flex; flex-direction: column; gap: 12px; }
  .sg-scanline { position: absolute; left: 0; right: 0; top: 0; height: 40px; pointer-events: none; opacity: 0; background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--accent) 26%, transparent), transparent); mix-blend-mode: screen; }
