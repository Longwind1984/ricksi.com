  .sg-gap-note { margin: 8px 0 0; font-size: 11.5px; line-height: 1.6; color: rgba(220,230,255,0.6); }

  .sg-judges { display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; align-items: center; }
  .sg-jbtn { flex: 1; min-width: 200px; text-align: left; padding: 11px 16px; border-radius: 14px; cursor: pointer; background: rgba(190,210,255,0.06); border: 1px solid rgba(190,210,255,0.18); transition: background-color .25s, border-color .25s, transform .35s var(--ease-liquid); -webkit-tap-highlight-color: transparent; }
  .sg-jbtn:hover { background: rgba(190,210,255,0.12); border-color: rgba(190,210,255,0.3); }
