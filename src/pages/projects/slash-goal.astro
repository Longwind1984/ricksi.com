  .sg-hero::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: 0; height: 200px; z-index: 1;
    background: linear-gradient(180deg, rgba(10,20,38,0) 0%, rgba(10,20,38,0.5) 60%, #0A1426 100%); pointer-events: none;
  }
  .sg-hero-inner { position: relative; z-index: 2; padding: 116px 0 92px; max-width: 880px; }
  .sg-crumb { margin-bottom: 22px; font-size: 12px; color: rgba(220,230,255,0.6); letter-spacing: 0.08em; }
  .sg-crumb a:hover { color: #fff; }
  .sg-kicker { margin-bottom: 18px; }
  .sg-h1 { margin: 0; font-family: var(--head); font-weight: 700; font-size: 52px; line-height: 1.2; letter-spacing: -0.02em; color: #fff; text-wrap: pretty; }
  .sg-sub { margin: 22px 0 0; font-size: 16.5px; line-height: 1.85; color: rgba(232,240,255,0.82); max-width: 660px; }
