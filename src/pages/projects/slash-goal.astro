    --sg-gray: rgba(190,210,255,0.55); --sg-gray-ink: rgba(220,230,255,0.9); --sg-gray-soft: rgba(190,210,255,0.06);
    --sg-green: #4FC785;
    position: relative; z-index: 1; overflow-x: clip;
