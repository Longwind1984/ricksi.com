          <div class="sec-head">
            <span class="mono sec-no">04</span>
            <div class="sec-title-row">
              <h2 class="sec-title"><a href="/frontier/" class="sec-title-link">前沿追踪</a></h2>
              <span class="mono sec-en">FRONTIER{ftTotal ? ` · ${ftTotal}` : ''}</span>
            </div>
            <span class="sec-desc">盯着 {ftPeopleCount} 位 AI 前沿人物的公开痕迹，每天抓取，模型梳理成中文{isFtSample && <em class="sample-badge">样例数据</em>}</span>
          </div>
          <!-- 头像锚点条：回答「这是什么模块」——盯人 -->
          <a class="ft-home-strip" href="/frontier/#people" aria-label="查看在追的人完整档案">
            {(ftData.people ?? []).map((p: any) => {
              const portrait = ftPortraitOf(p.slug);
              const on = ftActiveSlugs.has(p.slug);
              return (
                <span class:list={['ft-home-ava', { dim: !on }]} style={`--p-accent:${FT_ACCENT[p.domain] ?? '#7FB3F0'}`} title={p.name}>
