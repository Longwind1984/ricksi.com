                </div>
                <div>
                  <div class="mono stat-k">连续</div>
                  <div class="stat-v">{coding.streak}<span class="stat-unit">天</span></div>
                </div>
                <div>
                  <div class="mono stat-k">仓库</div>
                  <div class="stat-v">{coding.repos}<span class="stat-unit">个</span></div>
                </div>
              </div>
              {activityStamp && <div class="mono wb-stamp">数据更新于 {activityStamp}</div>}
            </div>
          </div>
        </section>
      </div>

      <!-- 03 知识库图谱 -->
      <div class="reveal">
        <section class="sec" id="knowledge">
          <div class="sec-head">
            <span class="mono sec-no">03</span>
            <div class="sec-title-row">
              <h2 class="sec-title">知识库图谱</h2>
              <span class="mono sec-en">KNOWLEDGE GRAPH</span>
            </div>
            <span class="sec-desc">与 Claude 共建的系统化知识工程——方法公开、来源标注</span>
          </div>
          <div class="kg-grid">
            <div class="kg-stage">
              <div class="kg-paper" id="kg-paper"></div>
              {graph && (
                <a class="kg-expand mono" href="/graph" aria-label="全屏探索 3D 知识图谱">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
                  全屏探索
                </a>
              )}
            </div>
            <div class="kg-side">
              <div class="kg-stats">
                {kbStats.map(([v, k]) => (
                  <div class="kg-stat"><span class="kg-stat-v">{v}</span><span class="kg-stat-k">{k}</span></div>
                ))}
              </div>
              {graph && (
                <div class="kg-search-row">
