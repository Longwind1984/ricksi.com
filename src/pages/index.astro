---
import Glass from '../layouts/Glass.astro';
import { getCollection } from 'astro:content';
import { PROJECTS } from '../data/projects';
import { INSTRUMENTS } from '../data/instruments';
import ProjRow from '../components/ProjRow.astro';
import InstrumentsPanel from '../components/InstrumentsPanel.astro';
import { loadSiteData, stamp } from '../lib/site-data.mjs';
import { scopedGraph } from '../lib/graph-scope.mjs';
import { gradOf } from '../lib/reading-ui.mjs';
import { sampleHeatmap, SAMPLE_USAGE, SAMPLE_CODING, SAMPLE_KB_STATS, SAMPLE_POSTS, SAMPLE_DAYS14, SAMPLE_READING } from '../lib/sample.js';
import WorkbenchGlance from '../components/WorkbenchGlance.astro';
import WorkbenchBoard from '../components/WorkbenchBoard.astro';

const { activity, usage, graph, reading: readingData } = loadSiteData();
// 首页知识库图谱 = AI 子图（full）；个人库 stub 仅在 /graph「全部」视图。stats 重算为自洽 AI 口径。
const aiGraph = graph ? scopedGraph(graph, 'ai') : null;

/* ---- 阅读（微信读书；无数据回退样例）。首页只留精简 teaser，完整内容在 /reading/ ---- */
const reading = readingData ?? SAMPLE_READING;
const readingStamp = readingData ? stamp(readingData.generated_at) : null;
const aiTopics = (reading as any).aiTopics ?? [];
// teaser 同样拆两组：能在线读的（有 epub）主推，其余收进折叠
const readableBooks = aiTopics.flatMap((t: any) =>
  (t.books ?? []).filter((b: any) => b.epub).map((b: any) => ({ ...b, topic: t.topic }))
);
const restBooks = aiTopics.flatMap((t: any) =>
  (t.books ?? []).filter((b: any) => !b.epub).map((b: any) => ({ ...b, topic: t.topic }))
);

/* ---- 工作台 · token 用量（真实 usage.json 或样例） ---- */
const u = usage ?? SAMPLE_USAGE;
const usageStamp = usage ? stamp(usage.generated_at) : null;
/* 近 14 日趋势：全源逐日合计（Claude Code + Codex + 其他 harness；实测/估算标记取自 Claude series，
   其他分源近日均为实测，不影响该标记） */
function days14From(u: { series?: Record<string, { total?: number; estimated?: boolean }>; sources?: any }) {
  const series = u.series || {};
  /* 除 Claude Code（逐日在顶层 series）外的全部分源：凡带 series 的都算——
     加新 harness 时这里无需再改（网页粗估无 series，自动不计入逐日） */
  const agentSeries: Record<string, { total?: number }>[] = Object.values(u.sources || {})
    .filter((s: any) => s?.series)
    .map((s: any) => s.series);
  const out = [];
  for (let i = 13; i >= 0; i--) {
    const dt = new Date();
    dt.setDate(dt.getDate() - i);
    const k = `${dt.getFullYear()}-${String(dt.getMonth() + 1).padStart(2, '0')}-${String(dt.getDate()).padStart(2, '0')}`;
    const rec = series[k];
    const total = (rec?.total || 0) + agentSeries.reduce((a, s) => a + (s[k]?.total || 0), 0);
    out.push({
      label: i === 0 ? '今天' : `${dt.getMonth() + 1}/${dt.getDate()}`,
      v: Math.round((total / 1e6) * 100) / 100,
      estimated: !!rec?.estimated,
    });
  }
  return out;
}
const days14 = usage?.series ? days14From(usage) : SAMPLE_DAYS14;

/* ---- 工作台 · 活动热力图（真实 activity.json 或 seed 5 样例） ---- */
type Cell = { l: number; d?: string; n?: number; b?: Record<string, number> };
let heatmapCols: Cell[][];
if (activity?.weeks) {
  heatmapCols = activity.weeks;
} else {
  heatmapCols = sampleHeatmap(22).map((col) => col.map((l) => ({ l })));
}
const coding = activity?.coding ?? SAMPLE_CODING;
const activityStamp = activity ? stamp(activity.generated_at) : null;

/* ---- 知识图谱统计 ---- */
const kbStats = aiGraph?.stats
  ? [
      [aiGraph.stats.notes.toLocaleString(), '篇笔记'],
      [aiGraph.stats.links.toLocaleString(), '条双链'],
      [String(aiGraph.stats.domains), '个主题域'],
    ]
  : SAMPLE_KB_STATS;

/* ---- Blog（内容集合，空则回退样例标题） ---- */
const allPosts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const posts = allPosts.length
  ? allPosts.slice(0, 3).map((p) => ({
      date: `${p.data.date.getFullYear()}.${String(p.data.date.getMonth() + 1).padStart(2, '0')}`,
      title: p.data.title,
      tag: p.data.tag,
      href: `/blog/${p.id}/`,
    }))
  : SAMPLE_POSTS;
const postsTotal = allPosts.length;

/* ---- 工作台组件透传：产出导向数字（真实/样例皆可） ---- */
const wbNotesLabel = String(kbStats[0][0]);
const wbProjectsCount = PROJECTS.length;
const wbInstrumentsCount = INSTRUMENTS.length;
const wbPostsCount = postsTotal || SAMPLE_POSTS.length;
const wbMethodReal = usage?.method?.real_days ?? null;
const wbMethodEst = usage?.method?.estimated_days ?? null;

/* ---- 主页知识库预览：构建期降采样 ----
   首页只展示 AI 知识库子图；完整个人知识图谱仍由 /graph 按需加载。 */
function downsampleGraph(g: any, cap = 160) {
  if (!g || g.nodes.length <= cap) return g;
  const byCluster = new Map<number, any[]>();
  for (const n of g.nodes) {
    if (!byCluster.has(n.cluster)) byCluster.set(n.cluster, []);
    byCluster.get(n.cluster)!.push(n);
  }
  const keep = new Set<number>();
  for (const list of byCluster.values()) {
    list.sort((a, b) => b.deg - a.deg);
    keep.add(list[0].id);
  }
  for (const n of [...g.nodes].sort((a, b) => b.deg - a.deg)) {
    if (keep.size >= cap) break;
    if (n.deg >= 2) keep.add(n.id);
  }
  const idMap = new Map<number, number>();
  const nodes = g.nodes
    .filter((n: any) => keep.has(n.id))
    .map((n: any, i: number) => {
      idMap.set(n.id, i);
      return { ...n, id: i };
    });
  const edges = g.edges
    .filter(([a, b]: number[]) => idMap.has(a) && idMap.has(b))
    .map(([a, b]: number[]) => [idMap.get(a), idMap.get(b)]);
  const counts = new Map<number, number>();
  for (const n of nodes) counts.set(n.cluster, (counts.get(n.cluster) || 0) + 1);
  return {
    ...g,
    nodes,
    edges,
    clusters: g.clusters.map((c: any) => ({ ...c, count: counts.get(c.id) || 0 })).filter((c: any) => c.count > 0),
    downsampled: { from: g.nodes.length, to: nodes.length },
  };
}
const homeGraph = downsampleGraph(aiGraph);

/* ---- 注入客户端的数据（工作台热力图明细 + 知识库预览） ---- */
const clientData = JSON.stringify({
  weeks: activity?.weeks ?? null,
  graph: homeGraph ?? null,
}).replace(/</g, '\\u003c');

/* 热力图维度（真实数据才有切换） */
const hmDims = [
  ['all', '全部'],
  ['git', '代码提交'],
  ['notes', '笔记'],
  ['ai', 'AI 会话'],
  ['gh', 'GitHub'],
];

/* 项目：featured 默认展示，其余收进「展开全部」（src/data/projects.ts 配置） */
const featured = PROJECTS.filter((p) => p.featured);
const moreProjects = PROJECTS.filter((p) => !p.featured);
const numbered = (list: typeof PROJECTS, offset = 0) =>
  list.map((p, i) => ({ ...p, no: String(i + 1 + offset).padStart(2, '0') }));
---

<Glass
  title="司豪杰 Rick Si · AI 产品经理"
  description="司豪杰 Rick Si — 在人工智能与人类的十字路口，我和 AI 的共享自留地：真实项目、实时工作台、知识库图谱、前沿追踪与写作。"
  isHome
  ogImage="/og/home.png"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: '司豪杰 Rick Si',
    url: 'https://ricksi.com',
    jobTitle: 'AI 产品经理',
    email: 'rick.si@outlook.com',
    sameAs: ['https://github.com/Longwind1984'],
  }}
>
  <main id="top">
    <!-- Hero · 全屏主视觉 + 工作台数据卡片 -->
    <section class="hero-photo">
      <div class="container hero-layout">
        <!-- 左侧：个人介绍 -->
        <div class="hero-text">
          <div class="mono kicker">AI 时代的思考与足迹</div>
          <h1 class="hero-title">在人工智能与人类的<br />十字路口</h1>
          <p class="hero-sub">
            hi 我是司豪杰，Rick。欢迎来到我与 AI 的共享自留地。我在这里追逐 AI 的飞速发展，也偶尔回头看看人类的来时路。
          </p>
          <!-- 紧凑目录条 -->
          <nav class="hero-index-strip" aria-label="页面目录">
            <a href="#projects" class="index-strip-item"><span class="mono">01</span> 项目</a>
            <a href="#knowledge" class="index-strip-item"><span class="mono">02</span> 知识库</a>
            <a href="#reading" class="index-strip-item"><span class="mono">03</span> 阅读</a>
            <a href="#blog" class="index-strip-item"><span class="mono">04</span> 写作</a>
          </nav>
        </div>
        <!-- 右侧：工作台精简收起卡（点击展开为全宽数据看板） -->
        <WorkbenchGlance
          u={u}
          heatmapCols={heatmapCols}
          notesLabel={wbNotesLabel}
          projectsCount={wbProjectsCount}
          instrumentsCount={wbInstrumentsCount}
          postsCount={wbPostsCount}
          isSample={!usage}
          usageStamp={usageStamp}
        />
      </div>
      <div class="mono hero-credit">云海之上 · 无人机自摄</div>
    </section>

    <div class="container">
      <!-- 01 项目 -->
      <div class="reveal">
        <section class="sec" id="projects">
          <div class="sec-head">
            <span class="mono sec-no">01</span>
            <div class="sec-title-row">
              <h2 class="sec-title">项目</h2>
              <span class="mono sec-en">PROJECTS · {PROJECTS.length}</span>
            </div>
            <span class="sec-desc">AI 时代的大玩具</span>
          </div>
          <InstrumentsPanel projectsCount={PROJECTS.length} />
          {numbered(featured).map((p) => <ProjRow {...p} />)}
          {moreProjects.length > 0 && (
            <>
              <div class="proj-extra" id="proj-extra">
                <div class="proj-extra-inner">
                  {numbered(moreProjects, featured.length).map((p) => <ProjRow {...p} />)}
                </div>
              </div>
              <div class="proj-expand-row">
                <button class="proj-expand mono" id="proj-expand" aria-expanded="false" aria-controls="proj-extra" data-total={PROJECTS.length}>
                  展开全部 {PROJECTS.length} 个项目 ↓
                </button>
              </div>
            </>
          )}
        </section>
      </div>

      <!-- 工作台口径说明已并入首屏数据看板（WorkbenchBoard 的「口径 v2」入口） -->

      <!-- 02 知识库 -->
      <div class="reveal">
        <section class="sec" id="knowledge">
          <div class="sec-head">
            <span class="mono sec-no">02</span>
            <div class="sec-title-row">
              <h2 class="sec-title">知识库</h2>
              <span class="mono sec-en">KNOWLEDGE BASE</span>
            </div>
            <span class="sec-desc">体系化笔记与真实双链；星系探索采用 Galaxy View</span>
          </div>
          <div class="kg-grid">
            <div class="kg-stage">
              <div class="kg-paper" id="kg-paper"></div>
              {graph && (
                <a class="kg-expand mono" href="/graph" aria-label="使用 Galaxy View 全屏探索知识图谱">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
                  Galaxy View · 全屏探索
                </a>
              )}
            </div>
            <div class="kg-side">
              <div class="kg-stats">
                {kbStats.map(([v, k]) => (
                  <div class="kg-stat"><span class="kg-stat-v">{v}</span><span class="kg-stat-k">{k}</span></div>
                ))}
              </div>
              {graph && (
                <div class="kg-search-row">
                  <input id="kg-search" class="kg-search mono" type="search" placeholder={`搜索 ${graph.stats.notes} 篇笔记…`} />
                  <span id="kg-search-hint" class="mono kg-search-hint"></span>
                </div>
              )}
              <div class="kg-legend" id="kg-legend"></div>
              {!graph && (
                <p class="kg-note" id="kg-note">悬停主题域可高亮对应节点。样例数据——完整知识库较大，部署版按需接入。</p>
              )}
              {graph && (
                <div class="kg-links">
                  <a class="kg-browse mono" href="/kb/">浏览全部笔记 →</a>
                </div>
              )}
            </div>
          </div>
        </section>
      </div>

      <!-- 03 阅读（微信读书） -->
      <div class="reveal">
        <section class="sec" id="reading">
          <div class="sec-head">
            <span class="mono sec-no">03</span>
            <div class="sec-title-row">
              <h2 class="sec-title"><a href="/reading/" class="sec-title-link">阅读</a></h2>
              <span class="mono sec-en">READING · WEREAD</span>
            </div>
            <span class="sec-desc">驻足，回望</span>
          </div>

          <div class="rd-stats">
            {[
              ['藏书', reading.stats.total, '本'],
              ['读完', reading.stats.finished, '本'],
              ...(reading.stats.readDays ? [['阅读天数', reading.stats.readDays, '天']] : [['在读', reading.stats.reading, '本']]),
              ...(reading.stats.hours ? [['累计时长', reading.stats.hours, '小时']] : []),
              ['划线与想法', reading.stats.notes.toLocaleString(), '条'],
            ].map(([k, v, unit]) => (
              <div><div class="mono stat-k">{k}</div><div class="stat-v">{v}<span class="stat-unit">{unit}</span></div></div>
            ))}
          </div>

          {aiTopics.length > 0 && (
            <div class="rd-ai rd-ai-compact">
              <div class="rd-ai-head">
                <span class="mono wb-label">AI 共创阅读 · 方法论展示</span>
                <span class="rd-ai-note">与 Claude 共写长文 → 转 ePub 精读，自制书不计入上方统计</span>
                <a class="mono rd-topic-link" href="/reading/#ai">话题与划线 →</a>
              </div>

              {readableBooks.length > 0 && (
                <div class="rd-teaser-readable">
                  <span class="mono rd-teaser-tag">可在线阅读 · {readableBooks.length} 本</span>
                  <div class="rd-rail">
                    {readableBooks.map((b: any) => (
                      <a class="rd-railbook" href={`/reading/${b.id}/read/`} title={`在线阅读《${b.title}》· ${b.topic}`}>
                        {b.cover ? (
                          <img class="rd-railbook-img" src={b.cover} alt={`《${b.title}》封面`} loading="lazy" />
                        ) : (
                          <div class="rd-railbook-img rd-aibook-cover">
                            <span class="mono rd-aibook-badge">AI 共创</span>
                            <span class="rd-aibook-title">{b.title}</span>
                          </div>
                        )}
                        <div class="rd-railbook-name">{b.title}</div>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {restBooks.length > 0 && (
                <details class="rd-teaser-more">
                  <summary class="rd-more-sum mono">
                    <span class="rd-more-label">更多共创书</span>
                    <span class="rd-more-right">
                      <span class="rd-more-count">{restBooks.length} 本</span>
                      <span class="rd-more-chev" aria-hidden="true">▾</span>
                    </span>
                  </summary>
                  <div class="rd-rail">
                    {restBooks.map((b: any) => (
                      <a class="rd-railbook" href={`/reading/${b.id}/`} title={`《${b.title}》· ${b.topic}${(b.highlights ?? []).length ? ` · ${b.highlights.length} 条划线` : ''}`}>
                        {b.cover ? (
                          <img class="rd-railbook-img" src={b.cover} alt={`《${b.title}》封面`} loading="lazy" />
                        ) : (
                          <div class="rd-railbook-img rd-aibook-cover">
                            <span class="mono rd-aibook-badge">AI 共创</span>
                            <span class="rd-aibook-title">{b.title}</span>
                          </div>
                        )}
                        <div class="rd-railbook-name">{b.title}</div>
                      </a>
                    ))}
                  </div>
                </details>
              )}
            </div>
          )}

          <div class="rd-grid">
            {reading.current && (
              <div class="rd-current">
                <div class="mono wb-label">最近在读</div>
                <a class="rd-current-card rd-card-link" href={readingData ? `/reading/${reading.current.id}/` : '/reading/'}>
                  {reading.current.cover ? (
                    <img class="rd-cover rd-cover-lg" src={reading.current.cover} alt={`《${reading.current.title}》封面`} loading="lazy" />
                  ) : (
                    <div class="rd-cover rd-cover-lg rd-cover-ph" style={`background:${gradOf(reading.current.id)}`}>
                      <span>{reading.current.title.slice(0, 1)}</span>
                    </div>
                  )}
                  <div class="rd-current-info">
                    <div class="rd-book-title">{reading.current.title}</div>
                    <div class="rd-book-author mono">{reading.current.author}</div>
                    <div class="rd-progress">
                      <div class="rd-progress-bar"><span style={`width:${reading.current.progress}%`}></span></div>
                      <span class="mono rd-progress-num">{reading.current.progress}%</span>
                    </div>
                    {reading.current.notes > 0 && (
                      <div class="mono rd-book-notes">{reading.current.notes} 条划线与想法 →</div>
                    )}
                  </div>
                </a>
              </div>
            )}
            <div class="rd-shelf-col">
              <div class="mono wb-label">书架 · 最近 9 本</div>
              <div class="rd-shelf">
                {reading.shelf.slice(0, 9).map((b) => (
                  <a class="rd-book" href={readingData ? `/reading/${b.id}/` : '/reading/'} title={`《${b.title}》${b.author ? ' · ' + b.author : ''}${b.finished ? ' · 已读完' : b.progress ? ` · ${b.progress}%` : ''}`}>
                    {b.cover ? (
                      <img class="rd-cover" src={b.cover} alt={`《${b.title}》封面`} loading="lazy" />
                    ) : (
                      <div class="rd-cover rd-cover-ph" style={`background:${gradOf(b.id)}`}>
                        <span>{b.title.slice(0, 1)}</span>
                      </div>
                    )}
                    {!b.finished && b.progress > 0 && <div class="rd-mini-bar"><span style={`width:${b.progress}%`}></span></div>}
                    <div class="rd-book-name">{b.title}</div>
                  </a>
                ))}
              </div>
              <div class="mono wb-stamp">
                {readingStamp ? `数据来自微信读书 · 更新于 ${readingStamp} · 书目人工筛选` : '样例书架——接入微信读书后展示真实在读与划线'}
              </div>
            </div>
          </div>
          <div class="proj-expand-row">
            <a class="proj-expand mono blog-all" href="/reading/">进入阅读页：全部书目与划线 →</a>
          </div>
        </section>
      </div>

      <!-- 04 思考与写作（持续迭代中 · 现阶段草稿） -->
      <div class="reveal">
        <section class="sec" id="blog">
          <div class="sec-head">
            <span class="mono sec-no">04</span>
            <div class="sec-title-row">
              <h2 class="sec-title"><a href="/blog/" class="sec-title-link">思考与写作</a></h2>
              <span class="mono sec-en">WRITING</span>
              <span class="tag mono wip-tag">持续迭代中 · 草稿</span>
            </div>
            <span class="sec-desc">大声思考，写明白才算想清楚——这块还在持续迭代，现阶段内容尚少、属草稿</span>
          </div>
          <div>
            {posts.map((p) => (
              <a href={p.href} class:list={['blog-row', { noop: p.href === '#' }]}>
                <span class="mono blog-date">{p.date}</span>
                <span class="blog-title">{p.title}</span>
                <span class="tag mono">{p.tag}</span>
                <span class="arrow">→</span>
              </a>
            ))}
          </div>
          {postsTotal > 0 && (
            <div class="proj-expand-row">
              <a class="proj-expand mono blog-all" href="/blog/">查看全部 {postsTotal} 篇 →</a>
            </div>
          )}
        </section>
      </div>
    </div>
  </main>

  <!-- 工作台数据看板浮层（由 Glance 卡展开；home.js 控制 open/close/焦点/ESC/scrim） -->
  <div class="wb-scrim" id="wb-scrim" hidden></div>
  <WorkbenchBoard
    u={u}
    coding={coding}
    days14={days14}
    heatmapCols={heatmapCols}
    activity={!!activity}
    hmDims={hmDims}
    notesLabel={wbNotesLabel}
    projectsCount={wbProjectsCount}
    instrumentsCount={wbInstrumentsCount}
    postsCount={wbPostsCount}
    isUsageSample={!usage}
    isActivitySample={!activity}
    usageStamp={usageStamp}
    activityStamp={activityStamp}
    methodReal={wbMethodReal}
    methodEst={wbMethodEst}
  />

  <script type="application/json" id="site-data" set:html={clientData} />
  <script>
    import '../scripts/home.js';
  </script>
</Glass>

<style>
  /* A2：工作台 Glance 卡「缩小 + 下移」，露出雪山主视觉焦点。
     只在桌面两栏布局（>1000px）生效；用 transform 不动栅格，避免破坏 hero 响应式。
     仅首页 hero 作用域（.hero-layout 在本页）。视觉草稿，待终审微调比例。 */
  @media (min-width: 1001px) {
    .hero-layout :global(.wb-glance) {
      align-self: end;
      transform: translateY(18px) scale(0.9);
      transform-origin: bottom right;
    }
  }
</style>
