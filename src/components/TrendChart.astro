---
/* 近 N 日 token 用量趋势 —— 构建时渲染的 SVG 面积图
   estimated 日用虚线段 + 空心点区分；峰值标注；点位带 data-tip 由 home.js 挂悬浮明细 */
interface Day {
  label: string;
  v: number; // 单位 M tokens
  estimated?: boolean;
}
interface Props {
  days: Day[];
}
const { days } = Astro.props;

const W = 540, H = 168, padL = 10, padR = 26, padT = 22, padB = 24;
const n = days.length;
const max = Math.max(...days.map((d) => d.v), 0.001);
const px = (i: number) => padL + (i * (W - padL - padR)) / Math.max(1, n - 1);
const py = (v: number) => padT + (1 - v / max) * (H - padT - padB);
const pts = days.map((d, i) => ({ ...d, x: px(i), y: py(d.v) }));

/* 折线按 estimated 分段（连续段独立 path，估算段虚线） */
type Seg = { est: boolean; d: string };
const segs: Seg[] = [];
for (let i = 1; i < n; i++) {
  const est = !!(pts[i].estimated || pts[i - 1].estimated);
  const d = `M${pts[i - 1].x.toFixed(1)} ${pts[i - 1].y.toFixed(1)} L${pts[i].x.toFixed(1)} ${pts[i].y.toFixed(1)}`;
  const last = segs[segs.length - 1];
  if (last && last.est === est) last.d += ' ' + d;
  else segs.push({ est, d });
}
const area =
  `M${pts[0].x.toFixed(1)} ${(H - padB).toFixed(1)} ` +
  pts.map((p) => `L${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ') +
  ` L${pts[n - 1].x.toFixed(1)} ${(H - padB).toFixed(1)} Z`;

const peakIdx = pts.reduce((m, p, i) => (p.v > pts[m].v ? i : m), 0);
const fmtV = (v: number) => (v >= 100 ? Math.round(v) : v >= 10 ? v.toFixed(1) : v.toFixed(2)) + 'M';
const hasEstimated = days.some((d) => d.estimated);
---

<div class="tc-wrap">
  <svg viewBox={`0 0 ${W} ${H}`} width="100%" role="img" aria-label="近 14 日 token 用量趋势">
    <defs>
      <linearGradient id="tc-fill" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="var(--accent)" stop-opacity="0.34"></stop>
        <stop offset="1" stop-color="var(--accent)" stop-opacity="0.02"></stop>
      </linearGradient>
    </defs>
    <line x1={padL} y1={H - padB} x2={W - padR} y2={H - padB} stroke="rgba(255,255,255,0.14)" stroke-width="1"></line>
    <path d={area} fill="url(#tc-fill)"></path>
    {segs.map((s) => (
      <path
        d={s.d}
        fill="none"
        stroke="var(--accent)"
        stroke-width="2"
        stroke-linecap="round"
        stroke-dasharray={s.est ? '4 5' : undefined}
        opacity={s.est ? 0.65 : 1}
      ></path>
    ))}
    {pts.map((p, i) => (
      <circle
        class="tc-pt"
        cx={p.x}
        cy={p.y}
        r={i === peakIdx || i === n - 1 ? 4 : 3}
        fill={p.estimated ? 'rgba(10,20,38,0.9)' : 'var(--accent)'}
        stroke="var(--accent)"
        stroke-width={p.estimated ? 1.4 : 0}
        data-tip={`${p.label} · ${fmtV(p.v)} tokens${p.estimated ? '（估算）' : ''}`}
      ></circle>
    ))}
    <text
      x={Math.min(pts[peakIdx].x, W - padR - 8)}
      y={Math.max(12, pts[peakIdx].y - 10)}
      text-anchor="middle"
      font-size="10.5"
      font-weight="700"
      fill="#FFFFFF"
      style="font-family: var(--head)"
    >{fmtV(pts[peakIdx].v)}</text>
    {pts.map((p, i) =>
      i % 3 === 0 || i === n - 1 ? (
        <text x={p.x} y={H - 7} text-anchor="middle" font-size="9" fill="rgba(240,245,252,0.55)" style="font-family: 'JetBrains Mono', monospace">{p.label}</text>
      ) : null
    )}
  </svg>
  {hasEstimated && (
    <div class="mono tc-legend">
      <span class="tc-leg-solid"></span> 实测
      <span class="tc-leg-dash"></span> 估算
    </div>
  )}
</div>

<style>
  .tc-wrap { position: relative; }
  .tc-pt { cursor: default; transition: r 0.15s; }
  .tc-pt:hover { r: 5; }
  .tc-legend { display: flex; align-items: center; gap: 8px; margin-top: 6px; font-size: 10px; color: rgba(255, 255, 255, 0.5); }
  .tc-leg-solid, .tc-leg-dash { display: inline-block; width: 18px; height: 0; border-top: 2px solid var(--accent); }
  .tc-leg-dash { border-top-style: dashed; opacity: 0.65; }
</style>
