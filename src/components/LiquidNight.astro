---
/**
 * 液态之夜 · Liquid Night —— 全屏背景组件（按需引入，不进默认布局）
 *
 * 两段 JS 逐字提取自已验收定稿的 .private/ai-health-teardown-v3.html：
 *   1) WebGL 域扭曲流场（钴蓝流明为体，金色矿脉是「不确定信号」，ECG 节律 beat()）
 *   2) initOrbFallback()：WebGL 不可用时的 Canvas 2D 粒子球回退
 * 仅两处适配性改动（逻辑与参数零改动）：
 *   - canvas 查找 getElementById('liquid-night') → querySelector('canvas.liquid-night')，查不到直接 return
 *   - 两段合并包进一个 IIFE + window.__liquidNightInit 幂等守卫，不泄漏任何全局变量
 *
 * 用法（任意页面 opt-in）：
 *   import LiquidNight from '../components/LiquidNight.astro';
 *   <LiquidNight />
 *
 * 脚本用 is:inline：源码逐字内联、不经打包改写；紧随 canvas 输出、解析到即执行，
 * 配合 __liquidNightInit 守卫保证只初始化一次（组件重复挂载/多次引入均安全）。
 */
---

<canvas class="liquid-night" aria-hidden="true" style="position:fixed;inset:0;width:100%;height:100%;z-index:-1;pointer-events:none"></canvas>

<script is:inline>
(function(){
  /* 幂等守卫：脚本被重复执行时只初始化一次；找不到挂载画布（未渲染组件）直接返回 */
  if (window.__liquidNightInit) return;
  var host = document.querySelector('canvas.liquid-night');
  if (!host) return;
  window.__liquidNightInit = true;

  /* —— 体征之球 · Vital Orb —— WebGL 不可用时的回退背景：
     880 光点的斐波那契球面，缓慢自转 + 静息心率呼吸；
     ~6% 金色「不确定信号」随机闪烁、衰减、复归。 */
  function initOrbFallback(){
    'use strict';
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var cv = document.createElement('canvas');
    cv.className = 'orb-fallback';
    cv.setAttribute('aria-hidden','true');
    document.body.insertBefore(cv, document.body.firstChild);
    var ctx = cv.getContext('2d');
    var DPR = Math.min(window.devicePixelRatio || 1, 1.75);
    var W = 0, H = 0;
    function resize(){
      W = window.innerWidth; H = window.innerHeight;
      cv.width = Math.round(W*DPR); cv.height = Math.round(H*DPR);
      ctx.setTransform(DPR,0,0,DPR,0,0);
    }
    resize();
    window.addEventListener('resize', resize);

    var N = 880, GA = Math.PI*(3-Math.sqrt(5)), pts = [];
    for (var i=0;i<N;i++){
      var y = 1-(i/(N-1))*2, r = Math.sqrt(Math.max(0,1-y*y)), th = GA*i;
      pts.push({x:Math.cos(th)*r, y:y, z:Math.sin(th)*r,
        gold:Math.random()<0.06, seed:Math.random()*6.283, sz:1.0+Math.random()*1.3});
    }
    var NM = 64, motes = [];
    for (var j=0;j<NM;j++){
      motes.push({x:Math.random(), y:Math.random(), s:0.4+Math.random()*0.9,
        a:0.03+Math.random()*0.09, vy:0.008+Math.random()*0.016, seed:Math.random()*6.283});
    }

    var mX=0, mY=0, tX=0, tY=0;
    if (window.matchMedia('(hover: hover)').matches){
      window.addEventListener('pointermove', function(e){
        mX = e.clientX/Math.max(1,W)-0.5; mY = e.clientY/Math.max(1,H)-0.5;
      }, {passive:true});
    }

    /* 心电图节律：P→QRS→T，3.15s 一拍 */
    function heartbeat(t){
      var p = (t % 3.15)/3.15;
      function g(c,w,a){ var d=(p-c)/w; return a*Math.exp(-d*d); }
      var v = g(0.14,0.030,0.14)+g(0.30,0.009,-0.10)+g(0.33,0.013,1.00)+g(0.37,0.010,-0.18)+g(0.58,0.050,0.24);
      return 1 + Math.max(0,Math.min(1,v))*0.03;
    }

    function render(t){
      ctx.clearRect(0,0,W,H);
      var mobile = W < 720, i, m;
      for (i=0;i<NM;i++){
        m = motes[i];
        var my = (m.y - t*m.vy) % 1; if (my < 0) my += 1;
        var tw = 0.55+0.45*Math.sin(t*0.8+m.seed*7);
        ctx.fillStyle = 'rgba(150,180,240,'+(m.a*tw).toFixed(3)+')';
        ctx.fillRect(m.x*W, my*H, m.s, m.s);
      }
      var cx = mobile ? W*0.5 : W*0.68;
      var cyc = mobile ? H*0.30 : H*0.46;
      var R = Math.min(W,H)*(mobile?0.44:0.35) * (reduce?1:heartbeat(t));
      var rotY = reduce ? 0.6 : t*0.055 + tX*0.6;
      var tilt = 0.42 + tY*0.18;
      var cyr = Math.cos(rotY), syr = Math.sin(rotY);
      var ctr = Math.cos(tilt), str = Math.sin(tilt);
      var glow = ctx.createRadialGradient(cx,cyc,R*0.1,cx,cyc,R*1.5);
      glow.addColorStop(0,'rgba(46,92,255,0.11)');
      glow.addColorStop(1,'rgba(46,92,255,0)');
      ctx.fillStyle = glow;
      ctx.fillRect(cx-R*1.5, cyc-R*1.5, R*3, R*3);
      var dim = mobile ? 0.72 : 1;
      for (i=0;i<N;i++){
        var p = pts[i];
        var x1 = p.x*cyr + p.z*syr;
        var z1 = -p.x*syr + p.z*cyr;
        var y1 = p.y*ctr - z1*str;
        var z2 = p.y*str + z1*ctr;
        var persp = 4.2/(4.2+z2);
        var front = (1-z2)/2;
        var a = (0.06+0.46*front*front) * dim;
        var col;
        if (p.gold){
          var f = 0.5+0.5*Math.sin(t*0.9+p.seed*13.7)*Math.sin(t*0.37+p.seed*5.1);
          f = f*f;
          col = 'rgba(224,185,98,'+(a*2.3*f+0.05).toFixed(3)+')';
        } else {
          col = 'rgba(126,164,255,'+a.toFixed(3)+')';
        }
        var s = p.sz*(0.65+0.55*front)*(p.gold?1.4:1);
        ctx.fillStyle = col;
        ctx.beginPath();
        ctx.arc(cx+x1*R*persp, cyc+y1*R*persp, s, 0, 6.283);
        ctx.fill();
      }
    }

    if (reduce){
      render(0);
      window.addEventListener('resize', function(){ render(0); });
      return;
    }
    var start = performance.now();
    function frame(now){
      var t = (now-start)/1000;
      tX += (mX-tX)*0.03; tY += (mY-tY)*0.03;
      render(t);
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }

  /* —— 液态之夜 · Liquid Night ——
     WebGL 域扭曲流场：钴蓝流明为体，金色矿脉是「不确定信号」；
     亮度与扭曲随心电图节律（P→QRS→T）涌动。WebGL 不可用时回退体征之球。 */
  (function(){
    'use strict';
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    /* 心电图节律：P 小波 → QRS 尖峰 → T 中波，3.15s 一拍（波形不变，节奏放慢三倍） */
    function beat(t){
      var p = (t % 3.15)/3.15;
      function g(c,w,a){ var d=(p-c)/w; return a*Math.exp(-d*d); }
      var v = g(0.14,0.030,0.14)   /* P */
            + g(0.30,0.009,-0.10)  /* Q */
            + g(0.33,0.013,1.00)   /* R */
            + g(0.37,0.010,-0.18)  /* S */
            + g(0.58,0.050,0.24);  /* T */
      return Math.max(0, Math.min(1, v));
    }
    var cv = document.querySelector('canvas.liquid-night');
    if (!cv){ return; }
    var gl = null;
    try {
      gl = cv.getContext('webgl',{alpha:false,antialias:false,depth:false,stencil:false,powerPreference:'low-power'})
        || cv.getContext('experimental-webgl');
    } catch(e){ gl = null; }
    if (!gl){ initOrbFallback(); return; }
    var VS = 'attribute vec2 p;void main(){gl_Position=vec4(p,0.0,1.0);}';
    var FS = [
      '#ifdef GL_FRAGMENT_PRECISION_HIGH',
      'precision highp float;',
      '#else',
      'precision mediump float;',
      '#endif',
      'uniform vec2 u_res;uniform float u_time;uniform vec2 u_mouse;uniform float u_beat;',
      'float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}',
      'float noise(vec2 p){vec2 i=floor(p);vec2 f=fract(p);vec2 u=f*f*(3.0-2.0*f);return mix(mix(hash(i),hash(i+vec2(1.0,0.0)),u.x),mix(hash(i+vec2(0.0,1.0)),hash(i+vec2(1.0,1.0)),u.x),u.y);}',
      'float fbm(vec2 p){float v=0.0;float a=0.5;mat2 r=mat2(0.8,0.6,-0.6,0.8);for(int i=0;i<5;i++){v+=a*noise(p);p=r*p*2.03+vec2(3.1,1.7);a*=0.5;}return v;}',
      'void main(){',
      'vec2 uv=(gl_FragCoord.xy-0.5*u_res)/min(u_res.x,u_res.y);',
      'float t=u_time*0.05;',
      'vec2 p0=uv*2.0;',
      'vec2 q=vec2(fbm(p0+vec2(0.0,t)),fbm(p0+vec2(5.2,t*0.7)));',
      'vec2 r=vec2(fbm(p0+(2.3+0.3*u_beat)*q+vec2(1.7,9.2)+u_mouse*0.18+0.13*t),fbm(p0+(2.3+0.3*u_beat)*q+vec2(8.3,2.8)-0.11*t));',
      'float f=fbm(p0+2.6*r);',
      'vec3 base=vec3(0.027,0.051,0.125);',
      'vec3 cobalt=vec3(0.09,0.19,0.46);',
      'vec3 elec=vec3(0.26,0.44,1.0);',
      'vec3 gold=vec3(0.88,0.72,0.38);',
      'vec3 col=mix(base,cobalt,smoothstep(0.36,0.92,f));',
      'col=mix(col,elec,smoothstep(0.60,0.97,f)*0.55);',
      'float fil=pow(1.0-abs(2.0*f-1.0),10.0);',
      'col+=elec*fil*(0.60+0.25*u_beat);',
      'float vein=pow(1.0-abs(2.0*q.y-1.0),14.0)*smoothstep(0.35,0.55,f)*(1.0-smoothstep(0.60,0.85,f));',
      'col+=gold*vein*(0.80+0.45*u_beat);',
      'col*=1.0+u_beat*0.07;',
      'float vig=smoothstep(1.45,0.30,length(uv*vec2(0.85,1.0)));',
      'col*=mix(0.42,1.0,vig);',
      'gl_FragColor=vec4(col,1.0);',
      '}'
    ].join('\n');
    function compile(t,s){ var sh=gl.createShader(t); gl.shaderSource(sh,s); gl.compileShader(sh); return gl.getShaderParameter(sh,gl.COMPILE_STATUS)?sh:null; }
    var vs = compile(gl.VERTEX_SHADER,VS), fs = compile(gl.FRAGMENT_SHADER,FS);
    if (!vs || !fs){ initOrbFallback(); return; }
    var pr = gl.createProgram();
    gl.attachShader(pr,vs); gl.attachShader(pr,fs); gl.linkProgram(pr);
    if (!gl.getProgramParameter(pr,gl.LINK_STATUS)){ initOrbFallback(); return; }
    gl.useProgram(pr);
    var buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    var loc = gl.getAttribLocation(pr,'p');
    gl.enableVertexAttribArray(loc);
    gl.vertexAttribPointer(loc,2,gl.FLOAT,false,0,0);
    var uRes=gl.getUniformLocation(pr,'u_res'), uT=gl.getUniformLocation(pr,'u_time'),
        uM=gl.getUniformLocation(pr,'u_mouse'), uB=gl.getUniformLocation(pr,'u_beat');
    var RS = Math.min(window.devicePixelRatio||1,1.5)*0.55, W=0, H=0;
    function resize(){
      W=window.innerWidth; H=window.innerHeight;
      cv.width=Math.round(W*RS); cv.height=Math.round(H*RS);
      gl.viewport(0,0,cv.width,cv.height);
    }
    resize();
    window.addEventListener('resize',resize);
    var mX=0,mY=0,tX=0,tY=0;
    if (window.matchMedia('(hover: hover)').matches){
      window.addEventListener('pointermove',function(e){
        mX=e.clientX/Math.max(1,W)*2-1; mY=e.clientY/Math.max(1,H)*2-1;
      },{passive:true});
    }
    function draw(t){
      tX+=(mX-tX)*0.03; tY+=(mY-tY)*0.03;
      gl.uniform2f(uRes,cv.width,cv.height);
      gl.uniform1f(uT,t);
      gl.uniform2f(uM,tX,-tY);
      gl.uniform1f(uB,reduce?0:beat(t));
      gl.drawArrays(gl.TRIANGLES,0,3);
    }
    if (reduce){
      draw(10);
      window.addEventListener('resize',function(){draw(10);});
      return;
    }
    var start = performance.now();
    (function frame(now){
      draw((now-start)/1000);
      requestAnimationFrame(frame);
    })(start);
  })();
})();
</script>

<style is:global>
/* 回退画布由 JS 动态插入 body，非 Astro 渲染，必须用全局样式（scoped 样式匹配不到）。
   与源文件 #liquid-night,.orb-fallback 规则一致；主画布样式已在元素上内联。 */
.orb-fallback{position:fixed;inset:0;width:100%;height:100%;z-index:-1;pointer-events:none;}
</style>
