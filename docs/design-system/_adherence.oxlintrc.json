{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/glass/**",
              "components/share/**",
              "ui_kits/workbench/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:MiSans|MiSans L3|Geist Mono|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: MiSans, MiSans L3, Geist Mono, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|style|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:tag|sample|prov-human|prov-co|prov-ai|wip)$/]",
        "message": "<Badge> variant must be one of 'tag' | 'sample' | 'prov-human' | 'prov-co' | 'prov-ai' | 'wip'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlogRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|title|tag|href|style|key|ref|className|style|children)$/]",
        "message": "<BlogRow> doesn't accept that prop. Declared props: date, title, tag, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|target|onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, target, onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:accent|ghost)$/]",
        "message": "<Button> variant must be one of 'accent' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|big)$/]",
        "message": "<Button> size must be one of 'default' | 'big'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|id|style|children|key|ref|className|style|children)$/]",
        "message": "<GlassSection> doesn't accept that prop. Declared props: variant, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassSection'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:section|index|card)$/]",
        "message": "<GlassSection> variant must be one of 'section' | 'index' | 'card'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Heatmap'] > JSXAttribute > JSXIdentifier[name!=/^(?:weeks|data|dims|activeDim|onDimChange|style|key|ref|className|style|children)$/]",
        "message": "<Heatmap> doesn't accept that prop. Declared props: weeks, data, dims, activeDim, onDimChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|items|active|onNavigate|cta|ctaHref|fixed|overHero|showSearch|style|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: brand, items, active, onNavigate, cta, ctaHref, fixed, overHero, showSearch, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|deg|href|featured|style|key|ref|className|style|children)$/]",
        "message": "<NoteChip> doesn't accept that prop. Declared props: title, deg, href, featured, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:no|title|desc|tags|icon|img|imgAlt|href|wip|style|key|ref|className|style|children)$/]",
        "message": "<ProjectRow> doesn't accept that prop. Declared props: no, title, desc, tags, icon, img, imgAlt, href, wip, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|hint|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: placeholder, hint, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:no|title|en|desc|href|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: no, title, en, desc, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShareCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|brand|module|kicker|title|excerpt|quote|badges|chips|stats|url|hook|qr|photoPosition|credit|style|key|ref|className|style|children)$/]",
        "message": "<ShareCard> doesn't accept that prop. Declared props: variant, brand, module, kicker, title, excerpt, quote, badges, chips, stats, url, hook, qr, photoPosition, credit, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShareCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:node|article|site)$/]",
        "message": "<ShareCard> variant must be one of 'node' | 'article' | 'site'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|email|github|cta|ctaHref|copyright|style|key|ref|className|style|children)$/]",
        "message": "<SiteFooter> doesn't accept that prop. Declared props: title, email, github, cta, ctaHref, copyright, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|sub|size|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: label, value, unit, sub, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|big|kg)$/]",
        "message": "<Stat> size must be one of 'default' | 'big' | 'kg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
